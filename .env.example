# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Docker Compose sets DATABASE_URL automatically via the environment block.
# For local development without Docker, point to your local Postgres instance.
DATABASE_URL=postgres://tripforge:tripforge@localhost:5432/tripforge

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
